# ── Erlbrew POS .dockerignore ─────────────────────────────────────────────────
# NEVER include .env in Docker image — pass via env_file in docker-compose
server/.env
server/node_modules
server/.env.*
node_modules
dist
.git
*.log
*.err
*.md
.env*
.github
# Don't include server source in frontend build context
server/src
server/uploads