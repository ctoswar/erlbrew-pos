# ── Erlbrew POS Print Server (Pi) ────────────────────────────────────────────
# Copy to .env and edit values. Keep .env on the Pi only — never commit it.

# Bluetooth MAC of your thermal printer
BT_PRINTER_MAC=BT_PRINTER_MAC

# Printer type: 'bluetooth' (direct RFCOMM), 'cups' (via lpr), or 'none' (log only)
PRINTER_TYPE=bluetooth

# Port to listen on (default: 9100)
PRINT_SERVER_PORT=9100

# For CUPS printing only:
# CUPS_PRINTER=thermal