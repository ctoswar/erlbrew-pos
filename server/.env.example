# ── Erlbrew POS Backend Configuration ──
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# Server
PORT=3001

# Database (MySQL)
DATABASE_URL=mysql://user:password@host:3306/erlbrew_pos

# JWT — Must be a strong random string in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# CORS — Comma-separated list of allowed origins
# Example: http://localhost:3000,http://192.168.1.100:3004
CORS_ORIGINS=http://localhost:3000

# Google Sheets Integration (optional — leave empty to disable)
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_KEY=